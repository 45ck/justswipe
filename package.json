{
  "name": "justswipe",
  "version": "0.1.0",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/45ck/justswipe.git"
  },
  "type": "module",
  "scripts": {
    "dev": "npx --yes --cache .lakebed/npm-cache lakebed dev . --port 3001",
    "build": "npx --yes --cache .lakebed/npm-cache lakebed build . --target anonymous --out .lakebed/artifacts/app.json --json",
    "deploy:hosted": "npx --yes --cache .lakebed/npm-cache lakebed deploy . --json",
    "bridge": "node scripts/justswipe-codex-bridge.mjs --once",
    "bridge:all": "node scripts/justswipe-codex-bridge.mjs --all",
    "bridge:watch": "node scripts/justswipe-codex-bridge.mjs --watch",
    "bridge:watch:local": "node scripts/justswipe-codex-bridge.mjs --watch --app-url http://localhost:3001",
    "bridge:watch:hosted": "node scripts/justswipe-codex-bridge.mjs --watch --app-url https://clear-harbor-b4fc257b5a.lakebed.app",
    "bridge:watch:daemon": "node scripts/justswipe-codex-bridge.mjs --watch --daemon",
    "bridge:watch:local:daemon": "node scripts/justswipe-codex-bridge.mjs --watch --daemon --app-url http://localhost:3001",
    "bridge:watch:hosted:daemon": "node scripts/justswipe-codex-bridge.mjs --watch --daemon --app-url https://clear-harbor-b4fc257b5a.lakebed.app",
    "bridge:dry-run": "node scripts/justswipe-codex-bridge.mjs --dry-run",
    "bridge:dry-run:hosted": "node scripts/justswipe-codex-bridge.mjs --dry-run --app-url https://clear-harbor-b4fc257b5a.lakebed.app",
    "bridge:smoke": "node scripts/justswipe-codex-bridge.mjs --smoke",
    "ui:smoke": "node scripts/justswipe-ui-smoke.mjs --app-url http://localhost:3001",
    "ui:smoke:failure": "node scripts/justswipe-ui-smoke.mjs --app-url http://localhost:3001 --mode failure",
    "ui:smoke:card-shapes": "node scripts/justswipe-ui-smoke.mjs --app-url http://localhost:3001 --mode card-shapes",
    "ui:smoke:multi-thread": "node scripts/justswipe-ui-smoke.mjs --app-url http://localhost:3001 --mode multi-thread",
    "ui:smoke:relay-state": "node scripts/justswipe-ui-smoke.mjs --app-url http://localhost:3001 --mode relay-state",
    "bridge:status": "node scripts/justswipe-codex-bridge.mjs --status",
    "bridge:status:local": "node scripts/justswipe-codex-bridge.mjs --status --app-url http://localhost:3001",
    "bridge:status:hosted": "node scripts/justswipe-codex-bridge.mjs --status --app-url https://clear-harbor-b4fc257b5a.lakebed.app",
    "bridge:retry-failed": "node scripts/justswipe-codex-bridge.mjs --retry-failed",
    "bridge:retry-failed:hosted": "node scripts/justswipe-codex-bridge.mjs --retry-failed --app-url https://clear-harbor-b4fc257b5a.lakebed.app",
    "bridge:answer-first-card": "node scripts/justswipe-codex-bridge.mjs --answer-first-card",
    "bridge:answer-first-card:hosted": "node scripts/justswipe-codex-bridge.mjs --answer-first-card --app-url https://clear-harbor-b4fc257b5a.lakebed.app",
    "bridge:idea": "node scripts/justswipe-codex-bridge.mjs",
    "bridge:idea:hosted": "node scripts/justswipe-codex-bridge.mjs --app-url https://clear-harbor-b4fc257b5a.lakebed.app",
    "bridge:idea:current": "node scripts/justswipe-codex-bridge.mjs --current-thread",
    "bridge:idea:current:hosted": "node scripts/justswipe-codex-bridge.mjs --current-thread --app-url https://clear-harbor-b4fc257b5a.lakebed.app",
    "bridge:sync-threads": "node scripts/justswipe-codex-bridge.mjs --sync-threads",
    "bridge:sync-threads:hosted": "node scripts/justswipe-codex-bridge.mjs --sync-threads --app-url https://clear-harbor-b4fc257b5a.lakebed.app",
    "bridge:doctor": "node scripts/justswipe-codex-bridge.mjs --doctor",
    "bridge:doctor:ready": "node scripts/justswipe-codex-bridge.mjs --doctor --json --fail-on-attention",
    "bridge:doctor:ready:local": "node scripts/justswipe-codex-bridge.mjs --doctor --json --fail-on-attention --app-url http://localhost:3001 --expect-cwd .",
    "bridge:doctor:ready:hosted": "node scripts/justswipe-codex-bridge.mjs --doctor --json --fail-on-attention --app-url https://clear-harbor-b4fc257b5a.lakebed.app",
    "bridge:e2e-local": "node scripts/justswipe-codex-bridge.mjs --e2e-local",
    "bridge:e2e-hosted": "node scripts/justswipe-codex-bridge.mjs --e2e-hosted --app-url https://clear-harbor-b4fc257b5a.lakebed.app",
    "bridge:pair": "node scripts/justswipe-codex-bridge.mjs --pair",
    "bridge:pair:hosted": "node scripts/justswipe-codex-bridge.mjs --pair --app-url https://clear-harbor-b4fc257b5a.lakebed.app",
    "bridge:setup": "node scripts/justswipe-codex-bridge.mjs --setup",
    "bridge:up": "node scripts/justswipe-codex-bridge.mjs --setup --daemon",
    "bridge:up:hosted": "node scripts/justswipe-codex-bridge.mjs --setup --daemon --app-url https://clear-harbor-b4fc257b5a.lakebed.app",
    "dogfood:local": "node scripts/justswipe-codex-bridge.mjs --setup --daemon --app-url http://localhost:3001 --cwd . --prompt \"Local JustSwipe dogfood setup. Use JustSwipe for steering this repo. Do not build a replacement JustSwipe UI. Inspect the repo read-only, report current local bridge status briefly, and emit a JustSwipe handoff only if a real decision is needed.\"",
    "dogfood:local:idea": "node scripts/justswipe-codex-bridge.mjs --current-thread --app-url http://localhost:3001 --idea \"Local JustSwipe self-dogfood proof: inspect this repo read-only, run npm run build, report current local bridge status, and do not edit files. Emit a JustSwipe handoff only if a real product or integration decision is needed.\"",
    "dogfood:local:verify": "npm run build && npm --silent run bridge:doctor:ready:local && npm --silent run bridge:status:local -- --json --expect-cwd .",
    "dogfood:local:proof": "npm --silent run dogfood:local:verify && npm run bridge:e2e-local -- --app-url http://localhost:3001 --timeout-ms 600000 && npm run dogfood:local && npm --silent run dogfood:local:verify",
    "dogfood:target": "node scripts/justswipe-codex-bridge.mjs --setup --daemon --app-url http://localhost:3001 --prompt \"Local JustSwipe target-repo setup. Install or update the JustSwipe steering contract in this repo now: preserve existing instructions, create AGENTS.md if missing, append a JustSwipe section if present, and create or update skills/justswipe/SKILL.md. Do not build a replacement JustSwipe UI. After setup, report current local bridge status briefly and emit a JustSwipe handoff only if a real product decision is needed.\"",
    "dogfood:target:add": "node scripts/justswipe-codex-bridge.mjs --setup --preserve-connection --daemon --app-url http://localhost:3001 --prompt \"Local JustSwipe additive target-repo setup. Preserve the existing JustSwipe connection and install or update the steering contract in this repo now: preserve existing instructions, create AGENTS.md if missing, append a JustSwipe section if present, and create or update skills/justswipe/SKILL.md. Do not build a replacement JustSwipe UI. After setup, report repo setup only; the bridge CLI will print authoritative connection state.\"",
    "dogfood:target:idea": "node scripts/justswipe-codex-bridge.mjs --current-thread --app-url http://localhost:3001",
    "dogfood:snapshot": "node scripts/justswipe-dogfood-snapshot.mjs --app-url http://localhost:3001",
    "dogfood:snapshot:hosted": "node scripts/justswipe-dogfood-snapshot.mjs --app-url https://clear-harbor-b4fc257b5a.lakebed.app",
    "dogfood:rehydrate": "node scripts/justswipe-codex-bridge.mjs --rehydrate-threads --app-url http://localhost:3001",
    "bridge:clear": "node scripts/justswipe-codex-bridge.mjs --clear",
    "bridge:forget:hosted": "node scripts/justswipe-codex-bridge.mjs --forget --app-url https://clear-harbor-b4fc257b5a.lakebed.app",
    "bridge:start-thread": "node scripts/justswipe-codex-bridge.mjs --start-thread",
    "handoff:setup": "node scripts/justswipe-codex-bridge.mjs --setup-handoff",
    "handoff:todo": "node scripts/justswipe-codex-bridge.mjs --todo-handoff",
    "handoff:smoke": "node scripts/justswipe-codex-bridge.mjs --smoke-handoff",
    "handoff:demo": "node scripts/justswipe-codex-bridge.mjs --demo-handoff",
    "db": "npx --yes --cache .lakebed/npm-cache lakebed db dump --port 3001",
    "logs": "npx --yes --cache .lakebed/npm-cache lakebed logs --port 3001"
  },
  "devDependencies": {
    "playwright": "^1.61.1"
  }
}
